# Neo4j Configuration
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=pole

# Groq API
GROQ_API_KEY=gsk_your_api_key_here

# Server Config
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_QUERIES=true
